# ------------------------------------------------------------------
# Market-state interpolation for reset/fixing dates
# ------------------------------------------------------------------

def _interpolated_market_state(
    self,
    target_date: date,
    scenario_dates: list[date],
    all_states: list[dict[str, RiskFactorSlice]],
) -> dict[str, RiskFactorSlice]:
    """Return the market state linearly interpolated to target_date.

    This is closer to RiskFlow's scenario-offset interpolation than using
    the nearest scenario date on or before the fixing date. It matters
    whenever CPI reference dates fall between exposure simulation dates.
    """
    if not scenario_dates:
        raise ValueError("scenario_dates cannot be empty")

    if target_date <= scenario_dates[0]:
        return all_states[0]

    if target_date >= scenario_dates[-1]:
        return all_states[-1]

    right_idx = bisect_right(scenario_dates, target_date)
    left_idx = right_idx - 1

    left_date = scenario_dates[left_idx]
    right_date = scenario_dates[right_idx]

    if target_date == left_date:
        return all_states[left_idx]
    if target_date == right_date:
        return all_states[right_idx]

    alpha = (target_date - left_date).days / (right_date - left_date).days

    left_state = all_states[left_idx]
    right_state = all_states[right_idx]
    interpolated: dict[str, RiskFactorSlice] = {}

    for name, left_slice in left_state.items():
        right_slice = right_state[name]

        if isinstance(left_slice, ScalarSlice):
            if not isinstance(right_slice, ScalarSlice):
                raise TypeError(f"Mismatched risk factor slice type for {name}")
            interpolated[name] = ScalarSlice(
                values=(
                    (1.0 - alpha) * left_slice.values
                    + alpha * right_slice.values
                )
            )

        elif isinstance(left_slice, CurveSlice):
            if not isinstance(right_slice, CurveSlice):
                raise TypeError(f"Mismatched risk factor slice type for {name}")
            interpolated[name] = CurveSlice(
                values=(
                    (1.0 - alpha) * left_slice.values
                    + alpha * right_slice.values
                ),
                tenors=left_slice.tenors,
            )

        elif isinstance(left_slice, SurfaceSlice):
            if not isinstance(right_slice, SurfaceSlice):
                raise TypeError(f"Mismatched risk factor slice type for {name}")
            interpolated[name] = SurfaceSlice(
                values=(
                    (1.0 - alpha) * left_slice.values
                    + alpha * right_slice.values
                ),
                tenors=left_slice.tenors,
                strikes=left_slice.strikes,
            )

        else:
            raise TypeError(
                f"Unsupported risk factor slice type for {name}: "
                f"{type(left_slice)}"
            )

    return interpolated
