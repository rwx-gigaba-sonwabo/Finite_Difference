def normalise_extracted(extracted_param, asset_name):
    """
    Robustly unwrap extracted_param regardless of nesting structure.
    Prints the exact key map so you can see what was found.
    """

    # ── Level 1: unwrap asset name if still top-level key ───────────────────
    if asset_name in extracted_param:
        extracted_param = extracted_param[asset_name]
        print(f"Unwrapped asset key '{asset_name}'")

    # ── Level 2: if it's STILL nested one more level (e.g. CalibrationInfo) -
    if hasattr(extracted_param, 'param'):
        extracted_param = extracted_param.param
        print("Unwrapped .param attribute")

    # ── Print exact keys as they exist in the dict ───────────────────────────
    print("\n--- Exact keys in extracted_param ---")
    for k in extracted_param.keys():
        v = extracted_param[k]
        print(f"  key='{k}'  type={type(v).__name__}  "
              f"preview={str(v)[:80]}")

    # ── Build a normalised dict with consistent key names ────────────────────
    # Map whatever key names exist to the expected names
    KEY_MAP = {
        # possible extracted key  →  normalised key
        'Reversion_Speed'         : 'Reversion_Speed',
        'ReversionSpeed'          : 'Reversion_Speed',
        'Reversion Speed'         : 'Reversion_Speed',
        'Alpha'                   : 'Reversion_Speed',
        'Mean Reversion Speed'    : 'Reversion_Speed',

        'Historical_Yield'        : 'Historical_Yield',
        'HistoricalYield'         : 'Historical_Yield',
        'Historical Yield'        : 'Historical_Yield',

        'Yield_Volatility'        : 'Yield_Volatility',
        'YieldVolatility'         : 'Yield_Volatility',
        'Yield Volatility'        : 'Yield_Volatility',
        'Reversion Volatility'    : 'Yield_Volatility',

        'Eigenvectors'            : 'Eigenvectors',
        'eigenvectors'            : 'Eigenvectors',

        'Rate_Drift_Model'        : 'Rate_Drift_Model',
        'Rate Drift Model'        : 'Rate_Drift_Model',

        'Princ_Comp_Source'       : 'Princ_Comp_Source',
        'Matrix_Type'             : 'Princ_Comp_Source',

        'Distribution_Type'       : 'Distribution_Type',
        'Distribution Type'       : 'Distribution_Type',
    }

    normalised = {}
    for raw_key, value in extracted_param.items():
        mapped = KEY_MAP.get(raw_key, raw_key)   # fallback: keep original
        normalised[mapped] = value
        if mapped != raw_key:
            print(f"  Remapped '{raw_key}' → '{mapped}'")

    return normalised


def to_tenor_dict(curve_obj, label=""):
    """
    Unpack any curve format into {tenor: value}.
    Handles:
      - list of [tenor, value]
      - list of (tenor, value) tuples
      - utils.Curve (iterable of pairs)
      - dict {tenor: value} already
      - nested dict with '.Curve' > 'data' key
    """
    d = {}
    if curve_obj is None:
        print(f"  WARNING [{label}]: curve_obj is None")
        return d

    # Already a plain dict — check if values are floats
    if isinstance(curve_obj, dict):
        # Could be {'.Curve': {'meta':[], 'data':[...]}}
        if '.Curve' in curve_obj:
            curve_obj = curve_obj['.Curve'].get('data', [])
            print(f"  [{label}]: unwrapped .Curve.data")
        else:
            # Assume {tenor_str: value} — convert keys to float
            try:
                return {float(k): float(v) for k, v in curve_obj.items()}
            except Exception as e:
                print(f"  WARNING [{label}]: dict unpack failed — {e}")
                return d

    # Iterable of pairs
    try:
        for pair in curve_obj:
            try:
                tenor = float(pair[0])
                value = float(pair[1])
                d[tenor] = value
            except Exception as inner:
                print(f"  WARNING [{label}]: bad pair {pair} — {inner}")
    except Exception as e:
        print(f"  WARNING [{label}]: not iterable "
              f"(type={type(curve_obj).__name__}) — {e}")

    return d


def compare_pca_params(calibrated_param, extracted_param,
                       asset_name, output_path=None):
    import pandas as pd
    import os

    # ── Unwrap and normalise both dicts ─────────────────────────────────────
    extracted_param  = normalise_extracted(extracted_param, asset_name)

    if hasattr(calibrated_param, 'param'):
        calibrated_param = calibrated_param.param

    # Normalise calibrated keys too
    calibrated_param = normalise_extracted(calibrated_param, asset_name) \
                       if asset_name in (calibrated_param or {}) \
                       else calibrated_param

    # ── Helpers ──────────────────────────────────────────────────────────────
    def abs_diff(a, b):
        try:
            return abs(float(a) - float(b)) \
                   if a is not None and b is not None else None
        except (TypeError, ValueError):
            return None

    def rel_diff(a, b):
        try:
            if a is None or b is None:
                return None
            denom = abs(float(b)) if abs(float(b)) > 1e-12 else 1e-12
            return abs(float(a) - float(b)) / denom * 100.0
        except (TypeError, ValueError):
            return None

    rows = []

    # ── 1. Reversion Speed ───────────────────────────────────────────────────
    cal_rs = calibrated_param.get('Reversion_Speed') \
             or calibrated_param.get('Alpha')
    ext_rs = extracted_param.get('Reversion_Speed')

    print(f"\nReversion Speed  cal={cal_rs}  ext={ext_rs}")

    rows.append({
        'Parameter'   : 'Reversion_Speed',
        'Tenor'       : 'scalar',
        'Calibrated'  : float(cal_rs) if cal_rs is not None else None,
        'Extracted'   : float(ext_rs) if ext_rs is not None else None,
        'Abs_Diff'    : abs_diff(cal_rs, ext_rs),
        'Rel_Diff_Pct': rel_diff(cal_rs, ext_rs),
    })

    # ── 2. Term structure parameters ─────────────────────────────────────────
    for param_key in ['Historical_Yield', 'Yield_Volatility']:
        cal_curve = to_tenor_dict(
            calibrated_param.get(param_key), f"cal {param_key}"
        )
        ext_curve = to_tenor_dict(
            extracted_param.get(param_key),  f"ext {param_key}"
        )
        print(f"{param_key}: cal={len(cal_curve)} tenors  "
              f"ext={len(ext_curve)} tenors")

        for t in sorted(set(cal_curve) | set(ext_curve)):
            rows.append({
                'Parameter'   : param_key,
                'Tenor'       : round(t, 6),
                'Calibrated'  : cal_curve.get(t),
                'Extracted'   : ext_curve.get(t),
                'Abs_Diff'    : abs_diff(cal_curve.get(t), ext_curve.get(t)),
                'Rel_Diff_Pct': rel_diff(cal_curve.get(t), ext_curve.get(t)),
            })

    # ── 3. Eigenvectors ──────────────────────────────────────────────────────
    cal_evs = calibrated_param.get('Eigenvectors', [])
    ext_evs = extracted_param.get('Eigenvectors', [])
    print(f"Eigenvectors: cal={len(cal_evs)} PCs  ext={len(ext_evs)} PCs")

    for i in range(max(len(cal_evs), len(ext_evs))):
        pc = f'PC{i+1}'
        cal_eval = cal_evs[i].get('Eigenvalue') if i < len(cal_evs) else None
        ext_eval = ext_evs[i].get('Eigenvalue') if i < len(ext_evs) else None

        rows.append({
            'Parameter'   : f'{pc}_Eigenvalue',
            'Tenor'       : 'scalar',
            'Calibrated'  : float(cal_eval) if cal_eval is not None else None,
            'Extracted'   : float(ext_eval) if ext_eval is not None else None,
            'Abs_Diff'    : abs_diff(cal_eval, ext_eval),
            'Rel_Diff_Pct': rel_diff(cal_eval, ext_eval),
        })

        cal_ev = to_tenor_dict(
            cal_evs[i].get('Eigenvector', []), f"cal {pc}"
        ) if i < len(cal_evs) else {}
        ext_ev = to_tenor_dict(
            ext_evs[i].get('Eigenvector', []), f"ext {pc}"
        ) if i < len(ext_evs) else {}

        for t in sorted(set(cal_ev) | set(ext_ev)):
            rows.append({
                'Parameter'   : f'{pc}_Eigenvector',
                'Tenor'       : round(t, 6),
                'Calibrated'  : cal_ev.get(t),
                'Extracted'   : ext_ev.get(t),
                'Abs_Diff'    : abs_diff(cal_ev.get(t), ext_ev.get(t)),
                'Rel_Diff_Pct': rel_diff(cal_ev.get(t), ext_ev.get(t)),
            })

    # ── 4. Build DataFrame ───────────────────────────────────────────────────
    df = pd.DataFrame(rows, columns=[
        'Parameter', 'Tenor',
        'Calibrated', 'Extracted',
        'Abs_Diff', 'Rel_Diff_Pct'
    ])

    for col in ['Calibrated', 'Extracted', 'Abs_Diff']:
        df[col] = df[col].apply(
            lambda x: round(x, 8) if isinstance(x, float) else x
        )
    df['Rel_Diff_Pct'] = df['Rel_Diff_Pct'].apply(
        lambda x: round(x, 4) if isinstance(x, float) else x
    )

    print(f"\n{'='*80}")
    print(f"  PCA Comparison — {asset_name}")
    print(f"{'='*80}")
    print(df.to_string(index=False))

    large = df[df['Rel_Diff_Pct'].apply(
        lambda x: isinstance(x, float) and x > 1.0
    )]
    if not large.empty:
        print(f"\n⚠️  {len(large)} differences > 1%:")
        print(large.to_string(index=False))
    else:
        print("\n✅ All within 1% tolerance.")

    if output_path:
        os.makedirs(os.path.dirname(output_path), exist_ok=True)
        df.to_csv(output_path, index=False)
        print(f"✅ Saved: {output_path}")

    return df
